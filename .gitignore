# macOS
.DS_Store

# Release zips built by tools/zip-mod.sh
*.zip

# Sandbox / scratch area (explicitly not part of versioned mods)
tmp/

# FS25 log artefacts that might land in the repo by accident
log.txt
**/modSettings/

# Cursor IDE local state
.cursor/

# Editor leftovers
*.swp
*~
.idea/
.vscode/

# Backup artefacts (created by tooling/agents; not versioned)
*.bak
*.bak_*
*.bak-*
*.ad-backup

# Generated reports (regenerate via tmp/mod_audit.py)
savegame_mod_audit.html

# Python virtualenvs (per-project convention) + bytecode
.venv/
__pycache__/
*.pyc

# fsmods runtime state (per-machine, not versioned)
.fsmods_state.json
tmp/roadmap/

# fsmods live config (per-machine state; use profiles.toml.example as template)
tools/fsmods/profiles.toml
