<?xml version="1.0" encoding="utf-8" standalone="no"?>
<modDesc descVersion="105">
	<author>Markus Uhl</author>
	<version>1.2.0.0</version>
	<multiplayer supported="false"/>
	<iconFilename>storeItem.png</iconFilename>
	<iconFilenameSmall>storeItem.png</iconFilenameSmall>
	<title>
		<en>NaviHelper</en>
		<de>NaviHelper</de>
	</title>
	<description>
		<en>Manual driving navigation: shows destination name, next-turn instruction and total distance, plus a route line on the ground. Set the route directly in the map with Ctrl+click (works with or without AutoDrive); further Ctrl+clicks add waypoints, Shift+click removes the last point.</en>
		<de>Manuelle Fahrt-Navigation: zeigt Zielname, Abbiegehinweis und Gesamtdistanz sowie eine Routenlinie am Boden. Route direkt in der Karte per Strg+Klick setzen (mit oder ohne AutoDrive); weitere Strg+Klicks fügen Zwischenpunkte hinzu, Umschalt+Klick löscht den letzten Punkt.</de>
	</description>
	<l10n filenamePrefix="l10n/l10n"/>
	<extraSourceFiles>
		<sourceFile filename="register.lua"/>
	</extraSourceFiles>
	<actions>
		<action name="NAVIHELPER_TOGGLE_UI" category="VEHICLE" axisType="HALF"/>
		<action name="NAVIHELPER_SET_TARGET_FROM_MAP" category="VEHICLE" axisType="HALF"/>
		<action name="NAVIHELPER_CLEAR_TARGET" category="VEHICLE" axisType="HALF"/>
		<action name="NAVIHELPER_SET_TARGET_AHEAD" category="VEHICLE" axisType="HALF"/>
	</actions>
	<inputBinding>
		<actionBinding action="NAVIHELPER_TOGGLE_UI">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_lalt KEY_n" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_ralt KEY_n" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_f10" axisComponent="+" neutralInput="0" index="1"/>
		</actionBinding>
		<actionBinding action="NAVIHELPER_SET_TARGET_FROM_MAP">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_lalt KEY_m" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_ralt KEY_m" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_f9" axisComponent="+" neutralInput="0" index="1"/>
		</actionBinding>
		<actionBinding action="NAVIHELPER_CLEAR_TARGET">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_lctrl KEY_n" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_rctrl KEY_n" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_f11" axisComponent="+" neutralInput="0" index="1"/>
		</actionBinding>
		<actionBinding action="NAVIHELPER_SET_TARGET_AHEAD">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_lalt KEY_t" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_ralt KEY_t" axisComponent="+" neutralInput="0" index="1"/>
			<binding device="KB_MOUSE_DEFAULT" input="KEY_f12" axisComponent="+" neutralInput="0" index="1"/>
		</actionBinding>
	</inputBinding>
</modDesc>
